use Array: all;
use StdIO: all;

specialize double[ 500, 500] matmul(double[ 500, 500] a, double[ 500, 500] b);
specialize double[1000,1000] matmul(double[1000,1000] a, double[1000,1000] b);
specialize double[1500,1500] matmul(double[1500,1500] a, double[1500,1500] b);

noinline
double[u,w] matmul(double[u,v] a, double[v,w] b)
{
    ControlFlow::touch();

    return { [i,j] -> sum({ [k] -> a[i,k] * b[k,j] }) };
}

int main()
{
    size = String::toi(CommandLine::argv(1));

    a = { [i,j] -> tod(i) | [i,j] < [size,size] };
    b = { [i,j] -> tod(j) | [i,j] < [size,size] };

    // Warmup runs
    for (i = 0; i < 5; i += 1) {
        a = matmul(a, b);
    }

    for (i = 0; i < 50; i += 1) {
        rapl = Rapl::raplStart(0);
        sec1, nsec1 = MTClock::gettime();

        a = matmul(a, b);

        sec2, nsec2 = MTClock::gettime();
        energy_uj = Rapl::raplStop(0, rapl);
        printf("%g,%g\n", MTClock::timediff(sec1, nsec1, sec2, nsec2), Rapl::tod(energy_uj));
    }

    return 0;
}
